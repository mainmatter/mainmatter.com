{#
List of logo items.

Configuration Options:
link: An array where each item is a string of the company name.
Add ", png" to the string to render a PNG instead of the default SVG.

Example usage:
{% set logoCompanies = ['Qonto', 'Trainline', 'Timify', 'Cardstack', 'Generali', 'Experteer, png'] %}
{{ logoList(logoCompanies) }}
#}
{% set caseStudies = collections.caseStudiesFeatured %}
{%- macro listItem(logoRaw) -%}
  {# 1. Check for the png flag and clean the logo name so slugs/text stay accurate #}
  {% set isPng = (', png' in logoRaw) or (',png' in logoRaw) %}
  {% set logo = logoRaw | replace(', png', '') | replace(',png', '') %}
  {% set caseUrl %}/cases/{{ logo | slug }}/{% endset %}
  
  {# 2. Dynamically set the exact file path based on the extension #}
  {% if isPng %}
    {% set imagePath %}/assets/images/logos/{{ logo | slug }}.png{% endset %}
  {% else %}
    {% set imagePath %}/logos/monochrome/{{ logo | slug }}.svg{% endset %}
  {% endif %}
  
  <li class="logo-list__item">
    {% if caseUrl | urlExists(caseStudies) %}
      <a href="{{ caseUrl }}" title="{{ logo }} case study">
        <div class="logo-list__image" aria-label="{{ logo }} logo">
          {# 3. Render standard image tag for PNGs, keep custom shortcode for SVGs #}
          {% if isPng %}
            <img src="{{ imagePath }}" alt="{{ logo }} logo" class="img">
          {% else %}
            {%
              svg imagePath,
              'img'
            %}
          {% endif %}
        </div>
      </a>
    {% else %}
      <div class="logo-list__image" aria-label="{{ logo }} logo">
        {# 4. Ensure the unlinked logos also get the PNG check! #}
        {% if isPng %}
          <img src="{{ imagePath }}" alt="{{ logo }} logo" class="img">
        {% else %}
          {%
            svg imagePath,
            'img'
          %}
        {% endif %}
      </div>
    {% endif %}
  </li>
{%- endmacro -%}

{%- macro logoList(logos, title, heading = "h2", headingClass = "h3", animate=true) -%}
  <section class="logo-list" id="logo-list">
    {% if title %}
      <div class="logo-list__title">
        {% if heading == 'h2' %}
          <h2 class="{{ headingClass }}">{{ title }}</h2>
        {% endif %}
        {% if heading == 'h4' %}
          <h4 class="{{ headingClass }}">{{ title }}</h4>
        {% endif %}
      </div>
    {% endif %}
    <div class="logo-list__wrapper">
      <div
        class="logo-list__inner"
        data-marquee
        {% if not animate %}data-marquee-disable{% endif %}
        style="--marquee-logo-count: {{ logos | length }};"
      >
        <ul class="logo-list__list">
          {% for logo in logos %}
            {{ listItem(logo) }}
          {% endfor %}
        </ul>
        <ul class="logo-list__list logo-list__list--duplicate" aria-hidden="true">
          {% for logo in logos %}
            {{ listItem(logo) }}
          {% endfor %}
        </ul>
      </div>
    </div>
    <button class="logo-list__button" data-marquee-controls>Pause animation</button>
  </section>
{%- endmacro -%}