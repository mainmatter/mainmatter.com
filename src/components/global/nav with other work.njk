<ul class="nav__list" role="list">
  {# 1. Get the standard nav items (Pages 1, 2, 3, etc.) #}
  {% set navPages = collections.all | eleventyNavigation %}

  {# 2. Manually find the 4 pages using the raw collection data #}
  {% set otherWorkChildren = [] %}
  {% for item in collections.all %}
    {% if item.data.eleventyNavigation.parent == "OtherWork" %}
      {# Create a small object that matches the nav format #}
      {%
        set childObj = {
          url: item.url,
          title: item.data.eleventyNavigation.title or item.data.title,
          order: item.data.eleventyNavigation.order
        }
      %}
      {% set otherWorkChildren = (otherWorkChildren.push(childObj), otherWorkChildren) %}
    {% endif %}
  {% endfor %}

  {# 3. Sort the children by their order #}
  {% set otherWorkChildren = otherWorkChildren | sort(false, false, 'order') %}

  {# 4. Create the Ghost Parent #}
  {%
    set ghostParent = {
      key: "OtherWork",
      title: "Other Work",
      order: 5,
      url: false,
      children: otherWorkChildren
    }
  %}

  {# 5. Clean up navPages: Remove any "accidental" top-level orphans and add our Ghost #}
  {% set filteredNav = [] %}
  {% for item in navPages %}
    {% if item.parent != "OtherWork" %}
      {% set filteredNav = (filteredNav.push(item), filteredNav) %}
    {% endif %}
  {% endfor %}

  {% set navPages = (filteredNav.push(ghostParent), filteredNav) | sort(false, false, 'order') %}
  {%- for entry in navPages -%}
  <li class="nav__item" {% if entry.children.length > 0 %}data-has-modal{% endif %}>
    {% if entry.key == "OtherWork" or entry.children.length > 0 %}
    {# --- DROPDOWN --- #}
    <details class="nav-submenu" data-has-submenu>
      <summary class="nav-submenu__toggle nav__link" data-menu-toggle>
        <span class="nav__link-text">{{ entry.title }}</span>
        <span class="nav__link-caret">{% include 'svg/caret.njk' %}</span>
      </summary>

      <div class="nav-submenu__menu" data-modal data-modal-desktop>
        <div class="nav-submenu__menu-inner">
          <ul class="nav-submenu__list" role="list">
            {# Use the children array we attached #}
            {%- for child in entry.children %}
              <li class="nav-submenu__list-item mb-2">
                <a href="{{ child.url | url }}" class="nav-submenu__link">
                  <div class="nav-submenu__link-wrap">
                    {% include 'svg/arrow.njk' %}
                    <h2 class="h4 nav-submenu__link-text">{{ child.title }}</h2>
                  </div>
                </a>
              </li>
            {%- endfor %}
          </ul>
        </div>
      </div>
    </details>
  </li>
</ul>{% else %}{# --- REGULAR LINK --- #}
