{% from "social-list.njk" import socialList %}
{% from "btn-primary.njk" import btnPrimary %}
{% set navPages = collections.all | eleventyNavigation %}

{% if page.url == '/playbook/' %}
  {% set ctaColor = 'purple' %}
{% else %}
  {% set ctaColor = 'aqua' %}
{% endif %}

<nav class="nav" id="nav">
  <div class="nav__wrapper container container--xl">
    {%- macro logo() -%}
      {%- include 'svg/logo.njk' -%}
      <span class="screenreader">Mainmatter</span>
    {%- endmacro -%}

    {% if page.url == '/' %}
      <h1 class="nav__logo">{{ logo() }}</h1>
    {% else %}
      <a href="/" class="nav__logo">{{ logo() }}</a>
    {% endif %}

    <button type="button" popovertarget="nav-menu" popovertargetaction="show" class="nav-button">
      {% include 'svg/menu.njk' %}
      <span class="screenreader">Open Menu</span>
    </button>

    <div id="nav-menu" popover>
      <button type="button" popovertarget="nav-menu" popovertargetaction="hide" class="nav-button">
        {% include 'svg/close.njk' %}
        <span class="screenreader">Close Menu</span>
      </button>

      {% macro navListItem(entry) -%}
        <li class="nav__item">
          {% if entry.url == '/work/' %}
            {% set parentChildCompare = '/cases/' %}
          {% else %}
            {% set parentChildCompare = entry.url %}
          {% endif %}
          <a
            href="{{ entry.url }}"
            class="nav__link-text {% if entry.url == page.url or (page.url and parentChildCompare in page.url) %}nav__link-text--active{% endif %}"
            {% if entry.url == page.url %}aria-current="page"{% endif %}
          >
            {% if entry.icon %}{% include entry.icon %}{% endif %}
            <span>{{ entry.title }}</span>
          </a>
        </li>
      {%- endmacro %}

      {% macro learningMaterialsNavItem() -%}
        <li class="nav__item nav__item--nested">
          <details class="nav__nested">
            <summary class="nav__nested-summary">
              <span>Learning material</span>
              {% include 'svg/caret.njk' %}
            </summary>
            <ul class="nav__nested-list">
              <li>
                <a
                  href="/c-to-rust-migration-book/"
                  class="nav__link-text {% if page.url == '/c-to-rust-migration-book/' %}nav__link-text--active{% endif %}"
                  target="_blank"
                  rel="noopener"
                  {% if page.url == '/c-to-rust-migration-book/' %}aria-current="page"{% endif %}
                >
                  <span>C to Rust Migration Book</span>
                </a>
              </li>
              <li>
                <a href="https://rust-exercises.com/" class="nav__link-text">
                  <span>Rust Exercises</span>
                </a>
              </li>
            </ul>
          </details>
        </li>
      {%- endmacro %}

      <ul class="nav__list nav__list--pinned">
        <!-- Pinned entries with icon -->
        {%- for entry in navPages -%}
          {%- if entry.pinned and entry.icon -%}
            {{ navListItem(entry) }}
          {%- endif -%}
        {%- endfor -%}
      </ul>

      <ul class="nav__list">
        <!-- Pinned entries without icon -->
        {%- for entry in navPages -%}
          {%- if entry.pinned and not entry.icon -%}
            {{ navListItem(entry) }}
          {%- endif -%}
        {%- endfor -%}

        <li class="nav__item">
          <button type="button" popovertarget="nav-overflow" class="nav-button nav__expandable">
            <span>More</span>
            {% include 'svg/caret.njk' %}
          </button>
        </li>
      </ul>

      <div id="nav-overflow" class="nav-popover" popover>
        <h2>More</h2>

        <ul class="nav__list nav__list--overflow">
          {%- for entry in navPages -%}
            {%- if not entry.pinned and entry.order <= 7 -%}
              {{ navListItem(entry) }}
            {%- endif -%}
          {%- endfor -%}

          {{ learningMaterialsNavItem() }}

          {%- for entry in navPages -%}
            {%- if not entry.pinned and entry.order > 7 -%}
              {{ navListItem(entry) }}
            {%- endif -%}
          {%- endfor -%}
        </ul>
      </div>

      {{
        btnPrimary({
        "label": "Contact us",
        "url": "/contact/"
        }, ctaColor, 'nav__cta' )
      }}
    </div>
  </div>
</nav>
