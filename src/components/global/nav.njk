{% from "social-list.njk" import socialList %}
{% from "btn-primary.njk" import btnPrimary %}
{% set navPages = collections.all | eleventyNavigation %}

{% if page.url == '/services/workshops/rust/' or page.url == '/playbook/' %}
  {% set ctaColor = 'purple' %}
{% else %}
  {% set ctaColor = 'aqua' %}
{% endif %}

<nav class="nav">
  <div class="nav__wrapper container container--xl">
    {%- macro logo() -%}
      {%- include 'svg/logo.njk' -%}
      <span class="screenreader">Mainmatter</span>
    {%- endmacro -%}

    {% if page.url == '/' %}
      <h1 class="nav__logo">{{ logo() }}</h1>
    {% else %}
      <a href="/" class="nav__logo">{{ logo() }}</a>
    {% endif %}

    <button type="button" popovertarget="nav-menu" popovertargetaction="show" class="nav-button">
      Open Menu
    </button>

    <div id="nav-menu" popover>
      <button type="button" popovertarget="nav-menu" popovertargetaction="hide" class="nav-button">
        Close Menu
      </button>

      {% macro navListItem(entry) -%}
        <li class="nav__item">
          <a href="{{ entry.url }}" {% if entry.url == page.url %}aria-current="page"{% endif %}>
            {% if entry.icon %}{% include entry.icon %}{% endif %}
            <span>{{ entry.title }}</span>
          </a>
        </li>
      {%- endmacro %}

      <ul class="nav__list nav__list--pinned">
        <!-- Pinned entries with icon -->
        {%- for entry in navPages -%}
          {%- if entry.pinned and entry.icon -%}
            {{ navListItem(entry) }}
          {%- endif -%}
        {%- endfor -%}
      </ul>

      <ul class="nav__list">
        <!-- Pinned entries without icon -->
        {%- for entry in navPages -%}
          {%- if entry.pinned and not entry.icon -%}
            {{ navListItem(entry) }}
          {%- endif -%}
        {%- endfor -%}

        <li class="nav__item">
          <button type="button" popovertarget="nav-overflow" class="nav-button">
            <span> Other work </span>
          </button>
        </li>
      </ul>

      <div id="nav-overflow" class="nav-popover" popover>
        <h2>Other work</h2>

        <ul class="nav__list nav__list--overflow">
          {%- for entry in navPages -%}
            {%- if not entry.pinned -%}
              {{ navListItem(entry) }}
            {%- endif -%}
          {%- endfor -%}
        </ul>
      </div>

      {{
        btnPrimary({
        "label": "Contact us",
        "url": "/contact/"
        }, ctaColor, 'nav__cta' )
      }}
    </div>
  </div>
</nav>
