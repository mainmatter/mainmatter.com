{{ logoList(logoCompanies) }}

<section class="py-7 background-aqua" id="our-clients-say">
  <div class="container container--lg quote-homepage">
    <h1 class="color-white">Our Clients Say</h1>
    {%
      set 'content' = {
      "text": "Working with Mainmatter's experts has been a great experience. They helped us develop a state-of-the-art data pipeline, mentored our internal team and introduced several improvements around our Rust code and infrastructure along the way.”",
      "source": "Andreas Hartel",
      "position": "Senior Engineer at Aleph Alpha",
      "styling": "redesigned"
      }
    %}
    {{ quote(content) }}
</section>

<section class="pt-7" id="what-sets-us-apart">
  <div class="container container--lg">
    <h1 class="mb-2">What Sets Us Apart</h1>
    <p class="medium">We focus on a set of core technologies to which we are deeply committed. For each, we build all-star teams around industry leaders, maintainers, authors and long-time contributors. We don’t just use the technology, we help shape it.</p>
    <p class="medium">We invest heavily in the communities we inhabit by running leading conferences such as <a href="https://eurorust.eu" class="link-black">EuroRust</a>, <a href="https://emberfest.eu" class="link-black">EmberFest</a>, and <a href="https://sveltesummit.com/" class="link-black">Svelte Summit</a>, supporting foundations like the Rust Foundation, contributing to open source, and creating widely used learning resources. We discover and establish new patterns and practices that advance the state of the art, through continuous experimentation and real-world application.</p>
</section>
{%
  set images = [
    ['eurorust', 'webp'],
    ['emberfest', 'svg'],
    ['sveltesummit', 'svg'],
    ['rust-foundation', 'png'],
    ['ember-initiative', 'svg'],
    ['svelte-custom-renderers', 'svg'],
    ['100-exercises-to-learn-rust', 'webp'],
