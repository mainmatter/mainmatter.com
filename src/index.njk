  set 'tech_3' = {
  "logo": "svelte",
  "link": "svelte-consulting",
  "linkText": "Svelte"
  }
%}
{%
  set 'content' = {
  "title": "Together We Go Further!",
  "text": "We know the tools and practices required for successful&nbsp;development. <br/>
We partner with you to solve your toughest tech challenges as&nbsp;teammates.",
  "image": "/assets/images/hero/toys-hero.webp",
  "alt": "Toys arranged in a neat grid",
  "loading": "eager",
  "technologies": [tech_1, tech_2, tech_3]
  }
%}
{{ colorHero('purple', content) }}

{%
  set logoCompanies = [
  'Timify',
  'BMW Car IT',
