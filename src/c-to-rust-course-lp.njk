              />
            </div>
            <div class="opensource-list__project-text">
              <h4 class="mb-015 medium">A deep-dive into our work for Redis at EuroRust 2025</h4>
            </div>
          </div>
          <div class="opensource-list__project-link">
            {%
              set link = {
              "label": 'Watch on YouTube',
              "url": 'https://youtube.com/watch?v=XklFGy3aUX4'
              }
            %}
            {{ btnSecondary( link, 'link-purple' ) }}
          </div>
        </li>
        <li class="opensource-list__project">
          <div>
            <div class="opensource-list__project-image">
              <img src="/assets/images/rust/eserde-blog-post.webp" alt="Rust logo" />
            </div>
            <div class="opensource-list__project-text">
              <h4 class="mb-015 medium">
                Blog post: eserde: Don't stop at the first deserialization error
