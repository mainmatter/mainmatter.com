{% from "image-banner-with-text.njk" import imageBannerWithText %}
{% from "service-cards.njk" import serviceCards %}
{% from "recent-posts.njk" import recentPosts %}
{% from "logo-list.njk" import logoList %}
{% from "cta-link.njk" import ctaLink %}
{% from "color-hero.njk" import colorHero %}
{% from "btn-secondary.njk" import btnSecondary %}
{% from "cta-banner.njk" import ctaBanner %}
{% from "image-aspect-ratio-with-button.njk" import imageAspectRatioWithButton %}
{% from "quote.njk" import quote %}
{% from "contact-form-LP.njk" import contactFormLP %}
{% from "global/default-newsletter-cta.njk" import defaultNewsletterCta %}
{% from "image-aspect-ratio.njk" import imageAspectRatio %}

{%
  set toc = {
    'What Sets Us Apart': '#team-stats',
    'How We Work': '#how-we-work',
    'Open Positions': '#hiring',
    'Let’s Talk': '#contact'
  }
%}
{%
  set 'content' = {
  "title": "About Mainmatter",
  "text": "We are a team of engineers, designers, strategists, and technology leaders. Fully remote, we are spread across Europe and work with clients around the world. We partner with clients for the long term, working like teammates and not just vendors. Our goal is to challenge thinking, build expertise and deliver truly sustainable solutions.",
  "image": "/assets/images/about-us/hero.webp",
  "alt": "Writing utencils",
  "loading": "eager",
    "containerType": "lp",
  "toc": toc
  }
%}
{{ colorHero('purple', content) }}

<section class="py-7 background-aqua">
  <h1 class="container container--lg mb-2 color-white" id="team-stats">What Sets Us Apart</h1>
  <div class="container container--lg p-2 p-3 background-white">
      <div class="stats-grid">
        <div class="stats-grid__wrapper">
          <div class="stats-grid__content">
            <h2 class="stats-grid__stat">28</h2>
            <p class="stats-grid__explanation medium">team members</p>
          </div>
          <div class="stats-grid__content">
            <h2 class="stats-grid__stat">20%</h2>
            <p class="stats-grid__explanation medium">of our time dedicated to open source work</p>
          </div>
          <div class="stats-grid__content">
            <h2 class="stats-grid__stat">X</h2>
            <p class="stats-grid__explanation medium">projects delivered</p>
          </div>
          <div class="stats-grid__content">
            <h2 class="stats-grid__stat">X+<span class="stats-grid__addnl-text"> years</span></h2>
            <p class="stats-grid__explanation medium">of coding experience</p>
          </div>
          <div class="stats-grid__content">
            <h2 class="stats-grid__stat">X<span class="stats-grid__addnl-text"> years</span></h2>
            <p class="stats-grid__explanation medium">average client retention</p>
          </div>
          <div class="stats-grid__content">
            <h2 class="stats-grid__stat">X</h2>
            <p class="stats-grid__explanation medium">events hosted</p>
          </div>
      </div>
      <p class="medium">
        We invest deeply in the technologies we work with. We build teams around industry leaders, maintainers, authors, and long-time contributors — people who don't just use the technology, but help shape it. We dedicate 20% of everyone’s time to open source work and run conferences like EuroRust, EmberFest and Svelte Summit. We are driven by a genuine curiosity for our core technologies and a passion for doing the work well. 
      </p>
      {%
        set link = {
        "label": 'View our work',
        "url": '/work/'
        }
      %}
      {{ btnSecondary( link, 'mt-2' ) }}
    </div>
  </div>
</section>

<section class="mobile-hidden">
  {%
    set 'content' = {
      "imgPath": "/assets/images/photos/balloons-top.jpeg",
      "alt": "Colorful balloons",
      "sizes": "100vw",
      "loading": "lazy",
      "sizesArray": [760, 1440, 1920],
      "aspectRatioDesktop": "32/6",
      "linkUrl": "#contact",
      "linkText": "Have a Project for Us?"
    }
  %}
  {{ imageAspectRatioWithButton(content) }}
</section>

<section class="pt-7" id="how-we-work">
  <div class="container container--lg">
    <div class="photo-grid">
      <img class="photo-grid__img-1" src="/assets/images/about-us/team.webp" alt="Team photo">
      <img class="photo-grid__img-2" src="/assets/images/about-us/workshop.webp" alt="Team workshop">
      <img class="photo-grid__img-3" src="/assets/images/about-us/venice.webp" alt="A boat in a Venice canal">
      <img class="photo-grid__img-4" src="/assets/images/about-us/hike.webp" alt="A group photo of the team on a hike, next to some goats">
      <img class="photo-grid__img-5" src="/assets/images/about-us/bowling.jpg" alt="Team member bowling">
    </div>
    <h1 class="mb-2 mt-2">How We Work</h1>
    <p class="medium">
      We are a fully remote team, spread across Europe and beyond. Remote-first is not a compromise for us, it’s a deliberate choice and investment into our team. For us, team culture is a top priority. Twice a year we all meet up in person, for workshops and exploring new European cities. Past trips include Venice, Strasbourg and Munich. These meetups matter deeply to us and are where we reflect on where we are heading, invest in relationships and simply enjoy each other's company.
    </p>
  </div>
</section>

<section class="mt-7 mb-5" id="hiring">
  <div class="container container--lg mb-6">
    <h1>Join Our Team</h1>
    {%
      set 'content' = {
      "text": "Working with Mainmatter's experts has been a great experience. They helped us develop a state-of-the-art data pipeline, mentored our internal team and introduced several improvements around our Rust code and infrastructure along the way.”",
      "source": "Andreas Hartel",
      "position": "Senior Engineer at Aleph Alpha",
      "styling": "redesigned"
      }
    %}
    {{ quote(content) }}
  </div>
  <div class="container container--lg mb-6">
    {%
      set link = {
      "label": 'See open positions',
      "url": ''
      }
    %}
    {{ btnSecondary( link, 'mt-2' ) }}

    {%
      set link = {
      "label": 'Submit a speculative application',
      "url": ''
      }
    %}
    {{ btnSecondary( link, 'mt-2' ) }}
</section>

{{ contactFormLP(null) }}

{{ defaultNewsletterCta('medium') }}

<section>
  {%
    set imageData = {
    "imgPath": "/assets/images/about-us/team-map.png",
    "alt": "Map of Europe highlighting locations Mainmatter team members work",
    "sizes": "100vw",
    "loading": "lazy",
    "sizesArray": [760, 1440, 1920]
    }
  %}
  {{ imageAspectRatio(imageData, "2/1", "2.5/1") }}
</section>
