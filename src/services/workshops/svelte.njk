---
layout: "base"
title: Svelte Workshops
description: "Public and team Svelte workshops by Mainmatter."
og:
  image: "/assets/images/workshops/svelte-workshops-og-image.jpg"
eleventyImport:
  collections: ["workshops"]
---

{% from "color-hero.njk" import colorHero %}
{% from "workshop-card.njk" import workshopCard %}
{% from "cta-banner.njk" import ctaBanner %}
{% from "quote.njk" import quote %}
{% from "logo-list.njk" import logoList %}
{% from "contact-form-LP.njk" import contactFormLP %}
{% from "tech-cards.njk" import techCards %}
{% from "secondary-feature.njk" import secondaryFeature %}
{% from "service-cta.njk" import serviceCta %}
{% from "image-aspect-ratio.njk" import imageAspectRatio %}


{% set heroEyebrow %}
  <a class="workshops-page-hero__eyebrow-link" href="/services/workshops/">
    <span class="workshops-page-hero__eyebrow-arrow">{% include 'svg/arrow.njk' %}</span>
    <span class="workshops-page-hero__eyebrow-text">All workshops</span>
  </a>
{% endset %}

{%
  set heroContent = {
  "eyebrow": heroEyebrow,
  "title": "Svelte Workshops",
  "text": "Lorem ipsum dolor sit amet, consectetur adipiscing elit. Etiam in nisi sed eros eleifend scelerisque a eu nisl. Ut eu sollicitudin magna. Nullam varius neque ante, a pulvinar ipsum luctus id.",
  "image": "/assets/images/hero/table-soccer.jpg",
  "alt": "Close-up photo of table soccer figures",
  "loading": "eager",
  "class": "workshops-page-hero",
  "toc": [
    ["Overview", "#overview"],
    ["Workshops", "#workshops"],
    ["Instructor", "#instructor"],
    ["Others Say", "#others-say"]
  ],
  "containerType": "lp"
  }
%}
{{ colorHero('purple', heroContent) }}

{% set svelteWorkshops = collections.workshops | filterByCollectionTag("svelte") %}

<div class="workshops-page">
  <section class="container container--xl my-10" id="workshops">
    <div class="workshops-page__intro">
      <div class="workshops-page__intro-text">
        <h2 class="mb-2">Svelte Workshops</h2>
        <p>
          We offer a range of workshops bookable for teams that want to grow – on-site or remote.
          We're also happy to prepare custom workshops – <a href="/contact/?service=workshops"
            >get in touch with us</a
          > to talk about what curriculum fits your team best!
        </p>
      </div>
    </div>

    <ul class="workshops-page__list">
      {% for workshop in svelteWorkshops %}
        <li>{{ workshopCard(workshop) }}</li>
      {% endfor %}
    </ul>
  </section>

  {%
    set teamCta = {
    "title": "Want to Book a Workshop for Your Team?",
    "text": "We are happy to tailor the curriculum to your needs. We can combine multiple workshops, pick and choose modules, as well as develop new content if desired.",
    "linkUrl": "/contact/",
    "linkText": "Get in touch"
    }
  %}
  {{ ctaBanner('purple', 'medium', teamCta) }}

  {%
    set logoCompanies = [
    'Redis',
    'Robin Hood',
    'Google',
    'AIS',
    'HashiCorp',
    'Faculty',
    'Keyrock',
    'BMW Car IT',
    'CERN'
    ]
  %}
  {{ logoList(logoCompanies, "We Have Trained Teams at", "h2", "h3") }}

  <section class="container container--lg my-10" id="instructor">
    <div class="split-content no-link">
      <div class="split-content__wrapper">
        <div class="split-content__content">
          <h5 class="workshops-page__instructor-eyebrow mb-015">
            <img src="/assets/images/icons/instructor.svg" alt="" loading="lazy" />
            <span>Our Expert Instructor</span>
          </h5>
          <h3 class="mb-2">Paolo Ricciuti</h3>
          <p>
            Paolo Ricciuti is a Svelte maintainer and one of the creators of
            <a href="https://sveltelab.dev">sveltelab.dev</a>, a REPL for SvelteKit.
          </p>
        </div>
        <div class="split-content__feature">
          {%
            set instructorImage = {
            "image": "/assets/images/authors/paoloricciuti.jpg",
            "alt": "Paolo Ricciuti",
            "loading": "lazy"
            }
          %}
          {{ secondaryFeature(instructorImage, 'split-content__author') }}
        </div>
      </div>
    </div>
  </section>

  <section class="container container--lg my-10" id="others-say">
    <h2 class="mb-4">Our Attendees Say...</h2>
    {%
      set quoteContent = {
      "text": "The work remains mysterious to me, but its importance becomes clearer with every passing day. The structure, guidance, and sense of purpose have exceeded all expectations.",
      "source": "Mark Scout",
      "position": "Department Chief, Macrodata Refinement @Lumon Industries",
      "styling": "redesigned"
      }
    %}
    {{ quote(quoteContent) }}

    {%
      set quoteContent = {
      "text": "Few people have the privilege of participating in work of this magnitude. While its full scope remains mysterious, the value of the mission becomes more apparent with every refinement.",
      "source": "Dylan G.",
      "position": "Macrodata Refiner @Lumon Industries",
      "styling": "redesigned"
      }
    %}
    {{ quote(quoteContent) }}

    {%
      set quoteContent = {
      "text": "Each refinement brings a sense of accomplishment that is difficult to describe. There is comfort in knowing that the work matters, even when its purpose remains beyond view.",
      "source": "Helly R.",
      "position": "Macrodata Refiner @Lumon Industries",
      "styling": "redesigned"
      }
    %}
    {{ quote(quoteContent) }}
  </section>

  {%
    set trainingMaterials = [
    {
      "title": "Svelte and SvelteKit",
      "link": "services/workshops/svelte-and-sveltekit/",
      "logo": "svelte"
    },
    {
      "title": "Progressive Enhancement With SvelteKit",
      "link": "services/workshops/progressive-enhancement-with-sveltekit/",
      "logo": "svelte"
    },
    {
      "title": "Testing Svelte and SvelteKit Applications",
      "link": "services/workshops/testing-svelte-sveltekit-applications/",
      "logo": "svelte"
    }
    ]
  %}

  {{ techCards('workshops-page-materials', 'Explore Our Other Training Materials', '', trainingMaterials) }}

  {{ serviceCta(["svelte"]) }}

  {{ contactFormLP("Svelte Workshops") }}

  <section>
    {%
      set imageData = {
      "imgPath": "/assets/images/photos/notebook-list.jpg",
      "alt": "Svelte workshop materials",
      "sizes": "100vw",
      "loading": "lazy",
      "sizesArray": [760, 1440, 1920]
      }
    %}
    {{ imageAspectRatio(imageData, "4/1", "35/19") }}
  </section>
</div>
